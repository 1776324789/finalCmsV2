 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 30pt; text-align: justify;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">在</span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">VR与艺术学院</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">教师党支部</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">主题党日活动上</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">，全体成员</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">通过</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">观看视频集中学习</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">习近平总书记主持召开进一步推动长江经济带高质量发展座谈时的重要讲话精神，并聆听了</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">VR与艺术学院教师党支部书记李书烨</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">讲授的</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">《一带一路中景德镇肩负引领的中国陶瓷文化传承与创新的使命》微党课</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">。</span></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: 等线; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 28px; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 30pt; text-align: justify;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">VR与艺术学院党总支书记梅龙代表班子就如何开展好主题党日活动作总结发言；李旺根就如何做好教师党支部建设工作提出具体意见。</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;">&nbsp;</span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: 等线; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 28px; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 30pt; text-align: justify;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">信息技术学院学生党支部全体成员在主题党日活动集中学习习近平总书记考察江西重要讲话精神，并观看廉政警示教育视频《缺失的敬畏》。</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">程杨胜</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">到会观摩并作点评讲话。</span></span></p><p style="box-sizing