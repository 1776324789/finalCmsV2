 none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); width: 600px; height: 400px;" width="600" height="400" border="0" vspace="0" title="" alt=""/></a></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;">&nbsp;</p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: center;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><a href="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2024-07-01%2021%3A08%3A399.jpg?Expires=2035199319&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=DfTmGRRujDe73mAWtGdpo%2BlAt5k%3D" data-fancybox="gallery" style="box-sizing: border-box; background-color: transparent; color: rgb(51, 122, 183); text-decoration-line: none; margin: 0px; padding: 0px; border: 0px; font-size: 16px; font-family: &quot;Microsoft YaHei&quot;; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; transition: all 0.3s ease-in 0s;"><img src="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2024-07-01%2021%3A08%3A399.jpg?Expires=2035199319&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=DfTmGRRujDe73mAWtGdpo%2BlAt5k%3D" class="imgstyle" style="box-sizing: border-box; border: 0px; vertical-align: baseline; margin: 0px; padding: 0px; list-style-type: none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); width: 600px; height: 400px;" width="600" height="400" border="0" vspace="0" title="" alt=""/></a></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;">&nbsp;</p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;">夜幕降临，音乐节和烟花秀为毕业生们带来了一场难忘的视听盛宴。烟花在夜空中绚烂绽放，光影交织，如梦似幻，照亮了整个校园，每一朵烟花都承载着毕业生们的梦想与希望，飞向璀璨的未来。井冈山2000余名市民也加入了庆祝的行列，他们的欢呼声和惊叹声此起彼伏，用手机记录下这难忘的瞬间，眼中充满了对过去的怀念和对未来的憧憬。</span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;">&nbsp;</p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: center;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><a href="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2024-07-01%2021%3A10%3A5110.jpg?Expires=2035199452&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=%2BkcSmomQ7Y2vnFtgfBhSikSs%2BzY%3D" data-fancybox="gallery" style="box-sizing: border-box; background-color: transparent; color: rgb(51, 122, 183); text-decoration-line: none; margin: 0px; padding: 0px; border: 0px; font-size: 16px; font-family: &quot;Microsoft YaHei&quot;; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; transition: all 0.3s ease-in 0s;"><img src="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2024-07-01%2021%3A10%3A5110.jpg?Expires=2035199452&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=%2BkcSmomQ7Y2vnFtgfBhSikSs%2BzY%3D" class="imgstyle" style="box-sizing: border-box; border: 0px; vertical-align: baseline; margin: 0px; padding: 0px; list-style-type: none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); width: 600px; height: 400px;" width="600" height="400" border="0" vspace="0" title="" alt=""/></a></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em;">&nbsp;</p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: center;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><a href="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2024-07-01%2021%3A23%3A10ZZZ4565.JPG%7Etplv-9lv23dm2t1-image.jpg?Expires=2035200191&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=PEDxoul0hpuJPqmoYh1FoJVvLow%3D" data-fancybox="gallery" style="box-sizing: border-box; background-color: transparent; color: rgb(51, 122, 183); text-decoration-line: none; margin: 0px; padding: 0px; border: 0px; font-size: 16px; font-family: &quot;Microsoft YaHei&quot;; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; transition: all 0.3s ease-in 0s;"><img src="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2024-07-01%2021%3A23%3A10ZZZ4565.JPG%7Etplv-9lv23dm2t1-image.jpg?Expires=2035200191&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=PEDxoul0hpuJPqmoYh1FoJVvLow%3D" class="imgstyle" style="box-sizing: border-box; border: 0px; vertical-align: baseline; margin: 0px; padding: 0px; list-style-type: none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); width: 600px; height: 400px;" width="600" height="400" border="0" vspace="0" title="" alt=""/></a></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;">&nbsp;</p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;">本次毕业典礼的成功举办，不仅为毕业生们留下了美好的回忆，也彰显了江西软件大学的办学理念和特色。同时，井冈山市领导的出席，更是体现了政府对教育事业的高度重视和对青年人才的关心与支持。</span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;">展望未来，江西软件大学的毕业生们，愿你们以坚定的步伐，传承红色基因，秉承“创业创新、知识管理”校训，牢记“学好软件、报效祖国”初心使命，用扎实的专业技能和创新精神，勇敢地书写属于你们的时代篇章，成就无愧于历史的精彩人生。</span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: justify;">&nbsp;</p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 2; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 2em; text-align: center;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><a href="https://aheadedu.oss-cn-shenzhen.aliyu