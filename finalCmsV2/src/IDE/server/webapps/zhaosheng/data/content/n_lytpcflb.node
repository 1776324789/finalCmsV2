px; border-bottom-color: rgb(0, 0, 0); border-left: none; list-style-type: none; vertical-align: bottom; -webkit-font-smoothing: antialiased; line-height: 1.42857; text-align: center; background-repeat: repeat-x; overflow-wrap: break-word;" height="30"><p style="box-sizing: border-box;margin-right: 1px;margin-left: 1px;border: 0px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">350</span></span></p></td><td valign="center" nowrap="nowrap" width="79" style="box-sizing: border-box; padding: 1px 1px 0px; border-top: none; border-right-width: 1px; border-right-color: rgb(0, 0, 0); border-bottom-width: 1px; border-bottom-color: rgb(0, 0, 0); border-left: none; list-style-type: none; vertical-align: bottom; -webkit-font-smoothing: antialiased; line-height: 1.42857; text-align: center; background-repeat: repeat-x; overflow-wrap: break-word;" height="30"><br/></td></tr></tbody></table><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">七</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">、考试：</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">高职单招工作遵循院校自主录取，省考试院监督的原则，以选拔适合高职教育特色，适合高职专业培养的考生为改革目标，采取</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">“文化素质+</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">职业</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">技能测试</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">”</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">考试两部分，总分满分为</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">450分，其中</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">文化素质</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">考试科目为：语文、数学并卷</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">200分，职业</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">技能测试</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">考试科目为；计算机基础</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">250分。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（一）考试时间：</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">3月</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">18</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">日（</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">星期六）上午</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（二）考试地点：</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">D11</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">教学楼</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（三）考试形式：</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">学校</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">统一命题，</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">线下</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">闭卷笔试</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">八、录取工作：</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)">&nbsp;&nbsp;&nbsp;<span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（一）录取原则</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">按照文化素质</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">+职业技能测试总分，从高分到低分择优录取，按专业计划录满为止，如有缺额可录取专业志愿服从调剂的考生，录取总分相同时，依次看职业技能测试、数学、语文单科成绩，考生在录取后不得退录。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（二）优惠政策</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">高职单招录取执行普通高校招生录取相关优惠政策。具体</span>&nbsp;<span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">见《江西省关于进一步深化高考加分改革的实施方案》（赣招</span>&nbsp;<span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">委字〔</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">2019〕25 号）。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（三）录取安排</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px 0px 0px 40px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">1.4月5日前，确定拟录取考生名单并在本校网站 进行公示。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px 0px 0px 40px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">2.4月10日-11日学校持录取数据库（光盘）到省教育考试院审核备案并办理录取手续。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px 0px 0px 40px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">3.4月15日前，考生在本校网站公布正式录取的考生名单，寄发本校印制的录取通知书。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">（四）录取说明</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px 0px 0px 40px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">1.通过高职单招录取的考生，与参加统一高考录取的考生享受相同待遇。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 16px;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased">&nbsp; &nbsp; 2.高职单招录取的考生须参加所在县（区）考试中心统一组织的高考体检。新生入校后，学校依据教育部、卫生部、中国残疾人联合会印发的《普通高等学校招生体检工作指导意见》和人力资源社会保障部、教育部、卫生部《关于进一步规范入学和就业体检项目维护乙肝表面抗原携带者入学和就业权利的通知》等有关要求以及学校招生章程中对身体条件的具体规定，对高考体检或新生入学复检结论涉及限报的单招考生可进行调整专业以及退学、休学等处理。</span></span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px 0px 0px 40px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="font-family: 仿宋; color: rgb(86, 64, 89); box-sizing: border-box; padding: 0px; border: 0px; font-size: 16px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased;">3.考生经高职单招录取后，不再具有参加统一高考及录取资格。</span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="font-family: 仿宋; color: rgb(86, 64, 89); box-sizing: border-box; padding: 0px; border: 0px; font-size: 16px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased;">&nbsp;</span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51)"><span style="font-family: 仿宋; color: rgb(86, 64, 89); box-sizing: border-box; padding: 0px; border: 0px; font-size: 16px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased;">&nbsp;</span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-indent: 37px;text-align: right"><span style="font-family: 仿宋; color: rgb(86, 64, 89); box-sizing: border-box; padding: 0px; border: 0px; font-size: 16px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;江西软件职业技术大学</span></p><p style="box-sizing: border-box;margin: 0px 1px;padding: 0px;border: 0px;font-size: 14px;font-family: &#39;Microsoft YaHei&#39;;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;line-height: 28px;text-wrap: wrap;overflow-wrap: break-word;color: rgb(51, 51, 51);text-align: right"><span style="font-family: 仿宋; color: rgb(86, 64, 89); box-sizing: border-box; padding: 0px; border: 0px; font-size: 16px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased;">2023年3月3日&nbsp; &nbsp;</span><span style="box-sizing: border-box;padding: 0px;border: 0px;font-size: 24px;font-family: 仿宋;list-style-type: none;vertical-align: baseline;-webkit-font-smoothing: antialiased;color: rgb(86, 64, 89)"> &nbsp; &nbsp;</span></p><p><br/></p>