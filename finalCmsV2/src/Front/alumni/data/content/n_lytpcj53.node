-type: none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); display: block;"/></span></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 28px; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 28pt;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 14pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;"><img src="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2023-10-20%2010%3A09%3A071697767691462.png?Expires=2013127747&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=xSshz42xK0EnSdTe8iWGi07AoWY%3D" alt="" width="650" height="373" style="box-sizing: border-box; border: 0px; vertical-align: baseline; margin: 0px auto; padding: 0px; font-family: &quot;Microsoft YaHei&quot;; list-style-type: none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); display: block;"/></span></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 28px; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 28pt;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 14pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: black !important;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;"><img src="https://aheadedu.oss-cn-shenzhen.aliyuncs.com/school_branch/jiiewebsite/img/2023-10-20%2010%3A10%3A231697767722583.png?Expires=2013127823&OSSAccessKeyId=LTAI4GEYjbEWU9Knh4iN17fd&Signature=f3avLhAYZWwLaCub9IbgUhBFiIQ%3D" alt="" width="650" height="601" style="box-sizing: border-box; border: 0px; vertical-align: baseline; margin: 0px auto; padding: 0px; font-family: &quot;Microsoft YaHei&quot;; list-style-type: none; -webkit-font-smoothing: antialiased; filter: saturate(1.1); display: block;"/></span></span></p><p style="box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 28px; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 28pt; text-align: justify;">&nbsp;</p><p style="text-align:justify;box-sizing: border-box; margin: 0pt 0pt 0.0001pt; padding: 0px; border: 0px; font-size: 10.5pt; font-family: Calibri; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; line-height: 26pt; color: rgb(51, 51, 51); text-wrap: wrap; background-color: rgb(255, 255, 255); text-indent: 30pt;"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: rgb(0, 0, 0);"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">近年来，我校高度重视语言文字工作，成立了语言文字工作委员会，语委会办公室设在教务处，制定了《江西软件职业技术大学语言文字委员会工作规则》，并列入学校教学管理制度汇编之中，有关规章制度健全，各部门通力合作，保障了学校语言文字工作有序开展，使语言文字规范化工作成为提高师生素质、建设文明校园的重要内容。今后，我们要继续努力，</span></span><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; font-size: 15pt; font-family: 微软雅黑; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; color: rgb(0, 0, 0);"><span style="box-sizing: border-box; margin: 0px; padding: 0px; border: 0px; list-style-type: none; vertical-align: baseline; -webkit-font-smoothing: antialiased; font-size: 16px !important;">推动学校语言文字工作再上新台阶。</span></span></p><p><br/></p>