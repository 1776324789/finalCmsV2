<section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; color: rgba(0, 0, 0, 0.9); font-family: system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif; font-size: 17px; letter-spacing: 0.544px; text-align: justify; white-space: normal; background-color: rgb(255, 255, 255); visibility: visible; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section data-role="title" data-tools="135编辑器" data-id="107046" data-color="#d82821" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"><section style="margin: 10px auto; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-align: center; visibility: visible;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: inline-block; visibility: visible;"><section style="margin: 0px 3px 0px 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; align-items: flex-end; visibility: visible;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"><section style="margin: 0px; padding: 6px 20px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; border-width: 1px; border-style: solid; border-color: rgb(238, 64, 58); visibility: visible;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 16px; letter-spacing: 1.5px; color: rgb(216, 40, 33); visibility: visible;"><strong data-brushtype="text" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;">《江西软件职业技术大学“先锋 ”奖学金评审办法（试行）》</strong></section></section><section style="margin: -2px 0px 0px 21px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 25px; height: 3px; background-color: rgb(238, 64, 58); overflow: hidden; visibility: visible;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"/></section><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; justify-content: flex-end; transform: translate(1px, 0px); visibility: visible;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 17px; height: 2px; background-color: rgb(222, 63, 63); overflow: hidden; visibility: visible;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"/></section></section></section><section style="margin: 0px 0px 0px 1px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 2px; height: 15px; background-color: rgb(222, 63, 63); flex-shrink: 0; visibility: visible;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"/></section></section></section></section></section><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"><section data-autoskip="1" style="margin: 4px 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; line-height: 30.75px; color: rgb(63, 63, 63); font-size: 14px; text-shadow: none; letter-spacing: 1.5px; visibility: visible;"><p style="margin-top: 7px; margin-bottom: 1px; margin-left: 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; visibility: visible; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; visibility: visible; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 1.5px; color: rgb(0, 0, 0); visibility: visible;">第一条</span></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 1.5px; color: rgb(0, 0, 0); visibility: visible;">&nbsp;</span></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 1.5px; color: rgb(0, 0, 0); visibility: visible;">为坚持党的教育方针，落实立德树人根本任务，彰显“以生为本&nbsp;”的教育理念，激励我校学生坚定理想，刻苦学习，勇于担当，敢为人先，乐于奉献，弘扬和传承“创业创新、知识管理”的校训，践行“三好一专、十一工程&nbsp;”育人体系，促进学生德智体美劳全面发展，经先锋软件集团公司提议，学校党政联席会研究，决定设立“先锋“奖学金，&nbsp;结合我校实际，特制定本办法。</span></span></p><p style="margin-top: 7px; margin-bottom: 1px; margin-left: 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; visibility: visible; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun; visibility: visible;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em; visibility: visible;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1.5px; visibility: visible;">第二条</span></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em; visibility: visible;"></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em; visibility: visible;"></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 1.5px; visibility: visible;">&nbsp;“先锋&nbsp;”奖学金由先锋软件集团公司设立。</span></span></p><p style="margin: 2px 15px 1px 4px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; visibility: visible; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; visibility: visible; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; visibility: visible;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1.5px; visibility: visible;">第三条</span></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1.5px; visibility: visible;">&nbsp;“先锋&nbsp;”奖学金评审对象为我校全日制大二及以上的本、专科在校学生，各学院每个年级评选1名。</span></span></p><p style="margin: 3px 15px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1.5px;">第四条</span></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1.5px;">&nbsp;“先锋&nbsp;”奖学金评审时间与国家奖学金评审工作同步进行。</span></span></p></section></section></section><p></p><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; color: rgba(0, 0, 0, 0.9); font-family: system-ui, -apple-system, BlinkMacSystemFont, &quot;Helvetica Neue&quot;, &quot;PingFang SC&quot;, &quot;Hiragino Sans GB&quot;, &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, Arial, sans-serif; font-size: 17px; letter-spacing: 0.544px; text-align: justify; white-space: normal; background-color: rgb(255, 255, 255); box-sizing: border-box !important; overflow-wrap: break-word !important;"><p style="margin-top: 0px; margin-bottom: 0px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; box-sizing: border-box !important; overflow-wrap: break-word !important;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></p><section data-role="title" data-tools="135编辑器" data-id="107046" data-color="#d82821" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section style="margin: 10px auto; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-align: center;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: inline-block;"><section style="margin: 0px 3px 0px 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; align-items: flex-end;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section style="margin: 0px 0px -2px 148.222px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 25px; height: 3px; background-color: rgb(238, 64, 58); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section><section style="margin: 0px; padding: 6px 20px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; border-width: 1px; border-style: solid; border-color: rgb(238, 64, 58);"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 16px; letter-spacing: 1.5px; color: rgb(216, 40, 33);"><strong data-brushtype="text" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;">第一章：奖励标准与申请条件</strong></section></section><section style="margin: -2px 0px 0px 21px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 25px; height: 3px; background-color: rgb(238, 64, 58); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; justify-content: flex-end; transform: translate(1px, 0px);"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 17px; height: 2px; background-color: rgb(222, 63, 63); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section></section></section><section style="margin: 0px 0px 0px 1px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 2px; height: 15px; background-color: rgb(222, 63, 63); flex-shrink: 0;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section></section></section></section></section><p style="margin: 2px 15px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">第五条</span></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">&nbsp;“先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">”奖学金评审奖励标准为每人每年8000</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">元，每学年评审优秀学生50名左右。</span></span></p><p style="margin: 2px 15px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">第六条</span></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em;"></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em;"></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 0px;">&nbsp;评审基本条件：</span></span></p><p style="margin: 2px 15px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); font-size: 15px; letter-spacing: 1px; text-indent: 2em; font-family: 宋体, SimSun;">（一）爱国爱校，积极上进，尊敬师长，友爱同学，遵纪守法，遵守大学生行为规范，具有良好的思想道德素质；</span></p><p style="margin: 2px 16px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px; font-size: 15px; font-family: 宋体, SimSun;">（二）勤奋学习，刻苦钻研，积极参加学术、科研和实践活动，具有较强的创新能力，学习成绩优异；</span></p><p style="margin: 2px 16px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">（三）身心健康，积极参加公益活动、实践劳动、文娱</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">活动等。</span></span></p><p style="margin: 2px 16px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); font-size: 15px; letter-spacing: 0px; text-indent: 2em; font-family: 宋体, SimSun;">（四）无违纪违法行为。</span></p><p style="margin: 2px 16px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">第七条</span></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em;"></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em;"></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 0px;">&nbsp;评审具体条件：</span></span></p><p style="margin: 2px 16px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 0px;">（一）学习成绩优秀，是</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(255, 0, 0);"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0px;">&quot;学习的先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0px;">”</span></span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 0px;">。学习勤奋，</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 1px;">综合成绩位列专业前10%，考试考查课程无补考；大学英语</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; letter-spacing: 0.034em; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; text-indent: 2em; color: rgb(0, 0, 0); letter-spacing: 1px;">单科成绩80分以上或通过英语等级考试者优先；计算机文化基础单科成绩80分以上或通过国家计算机等级考试者优先；</span></span></p><p style="margin: 4px 20px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(0, 0, 0); letter-spacing: 0px;">（二）坚持锻炼身体，是</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(255, 0, 0);"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">“运动的先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: -6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">”</span></span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">。身体健康，</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">心理素质平稳，体育测评成绩良好及以上；</span></span></span></p><p style="margin: 2px 15px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(0, 0, 0); letter-spacing: 0px;">（三）具有创业创新精神，是</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(255, 0, 0);"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">“创新的先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: -6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">”</span></span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">。积极参</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">加“互联网+</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">”、</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -9px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">“挑战杯</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">”等各级各类创新创业大赛，获得省级及以上奖励者优先；或进行自主创业活动，取得一定</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">的成效。</span></span></span></p><p style="margin: 2px 16px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(0, 0, 0); letter-spacing: 0px;">（四）愉悦学习生活，是</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(255, 0, 0);"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">“快乐的先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: -6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">”</span></span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">。积极参加学</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">校各项文体活动，加入学生社团或其它学生组织一年（含）以上，获评一次校级及以上奖励者优先；</span></span></span></p><p style="margin: 2px 19px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(0, 0, 0); letter-spacing: 0px;">（五）具有劳动意识和工匠精神，是</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(255, 0, 0);">“劳动的先锋<span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; letter-spacing: 0px;">”</span></span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">。</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">积极参加劳动，劳动实践课成绩优秀；积极</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">参加技能竞赛，</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">至少获得一次校级竞赛奖励，获得省级竞赛奖励者优先。</span></span></span></p><p style="margin: 2px 16px 1px 2px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px; font-size: 15px; font-family: 宋体, SimSun;">（六）在同等符合诸多条件的情况下，按照学习综合成绩高分优先、参加创新创业比赛优先的原则确定。</span></p><section data-role="title" data-tools="135编辑器" data-id="107046" data-color="#d82821" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section style="margin: 10px auto; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-align: center;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: inline-block;"><section style="margin: 0px 3px 0px 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; align-items: flex-end;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section style="margin: 0px 0px -2px 128.972px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 25px; height: 3px; background-color: rgb(238, 64, 58); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section><section style="margin: 0px; padding: 6px 20px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; border-width: 1px; border-style: solid; border-color: rgb(238, 64, 58);"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 16px; letter-spacing: 1.5px; color: rgb(216, 40, 33);"><strong data-brushtype="text" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;">第二章：申请与评审程序</strong></section></section><section style="margin: -2px 0px 0px 21px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 25px; height: 3px; background-color: rgb(238, 64, 58); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; justify-content: flex-end; transform: translate(1px, 0px);"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 17px; height: 2px; background-color: rgb(222, 63, 63); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section></section></section><section style="margin: 0px 0px 0px 1px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 2px; height: 15px; background-color: rgb(222, 63, 63); flex-shrink: 0;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></section></section></section></section></section><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section data-autoskip="1" style="margin: 4px 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; line-height: 30.75px; color: rgb(63, 63, 63); font-size: 14px; text-shadow: none; letter-spacing: 1.5px;"><p style="margin: 2px 19px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">第八条</span></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">&nbsp;</span></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">“先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">”奖学金评审坚持公开、公平、公正、</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">择优的原则，每学年评审1次。</span></span></p><p style="margin: 2px 19px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-indent: 2em; letter-spacing: 0.034em;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">第九条</span></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-indent: 2em; letter-spacing: 0.034em;"></strong><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-indent: 2em; letter-spacing: 0.034em;"></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-indent: 2em; letter-spacing: 0.034em;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 2px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">评审程序</span></span></span></p><p style="margin: 2px 16px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">（一）广泛宣传。各学院要成立评审小组，广泛开展“&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">”奖学金宣传教育，引导学生及时了解“先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">”奖学金设立的目的和意义、</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">申请办理流程和工作时限。</span></span></p><p style="margin: 2px 11px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">（二）个人申请、班级评议及学院评审。各班级根据“&nbsp;先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">”奖学金评审条件，引导符合条件的学生主动申报。在辅导员指导下，班级成立学生代表为成员的班级评审小组，通过民主评议等方式确定拟推荐学生名单。拟推荐学生名单</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">确定后，在全班进行不少于3个工作日的公示，如无异议，&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">报送学院评审小组。各学院拟推荐学生名单确定后，在学院范围内进行不少于5个工作日的公示，审核后提交申请材料</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">至学工处。</span></span></p><p style="margin: 2px 11px 1px 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px; text-indent: 2em; font-size: 15px; font-family: 宋体, SimSun;">（三）学校审查</span></p><p style="margin-top: 2px; margin-bottom: 1px; margin-left: 3px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">学工（部）处汇总各学院“先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">”奖学金推荐学生材料，</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0);">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">审查无异议后，将评审情况及结果提请学校评审小组审议。</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-indent: 1px; letter-spacing: 0px;">，提请校长办公会审定。</span></span></p><p style="margin-top: 4px; margin-bottom: 1px; margin-left: 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; font-family: 宋体, SimSun;"><strong style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">第十条</span></strong><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">同一学年内，获得国家奖学金、</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -6px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">国家励志奖学金的学生，不能同时获评“先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -8px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 1px;">”奖学金；但获得国家助学</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">金的学生，可以同时获得“先锋</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: -7px;">&nbsp;</span><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; color: rgb(0, 0, 0); letter-spacing: 0px;">”奖学金。</span></span></p><p style="margin-top: 4px; margin-bottom: 1px; margin-left: 1px; padding: 0px; outline: 0px; max-width: 100%; clear: both; min-height: 1em; color: rgba(255, 255, 255, 0.65); font-size: 17px; font-variant-numeric: normal; font-variant-east-asian: normal; letter-spacing: 0.544px; widows: 1; line-height: 2em; text-indent: 2em; font-family: system-ui, -apple-system, BlinkMacSystemFont, Arial, sans-serif; box-sizing: border-box !important; overflow-wrap: break-word !important;"><span style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; font-size: 15px; color: rgb(0, 0, 0); letter-spacing: 0px; font-family: 微软雅黑, &quot;Microsoft YaHei&quot;;"></span></p><section data-role="title" data-tools="135编辑器" data-id="107046" data-color="#d82821" style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section style="margin: 10px auto; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; text-align: center;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: inline-block;"><section style="margin: 0px 3px 0px 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; display: flex; align-items: flex-end;"><section style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"><section style="margin: 0px 0px -2px 109.722px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important; width: 25px; height: 3px; background-color: rgb(238, 64, 58); overflow: hidden;"><br style="margin: 0px; padding: 0px; outline: 0px; max-width: 100%; box-sizing: border-box !important; overflow-wrap: break-word !important;"/></